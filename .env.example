# Database
# SQLite for local development:
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL for production (Neon/Supabase):
# DATABASE_URL="postgresql://user:pass@host:5432/database?sslmode=require"

# Whop OAuth
NEXT_PUBLIC_WHOP_CLIENT_ID=app_xxxxxxxxx
WHOP_CLIENT_SECRET=your_client_secret
NEXT_PUBLIC_WHOP_REDIRECT_URI=http://localhost:3000/api/auth/whop/callback

# Whop Webhooks
WHOP_WEBHOOK_SECRET=your_webhook_secret

# OpenAI (for AI copywriting)
OPENAI_API_KEY=sk-xxxxxxxx

# App URL (for published funnels)
NEXT_PUBLIC_APP_URL=http://localhost:3000
